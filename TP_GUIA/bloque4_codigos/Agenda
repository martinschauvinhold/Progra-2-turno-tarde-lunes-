import Implementacion.DiccionarioSimpleEstatico;
import Interface.DiccionarioSimpleTDA;

public class Main {
    public static void main(String[] args) {
        // 1. Configuración del Diccionario
        DiccionarioSimpleTDA agenda = new DiccionarioSimpleEstatico();
        agenda.InicializarDiccionario();

    

        System.out.println("--- Cargando Agenda ---");
        
        // . Operaciones: Clave (Nombre) / Valor (Teléfono)
        agenda.Agregar(Martin, 1144556677);
        agenda.Agregar(Juan, 1199887766);
        
        // 4. Actualización de Valor (Martin cambia de número)
        // El Diccionario Simple detecta que la clave 'Martin' ya existe y pisa el valor
        agenda.Agregar(Martin, 1122334455);

        System.out.println("¿Martin está en la agenda?: " + existe(agenda, Martin));
        System.out.println("¿Juan está en la agenda?: " + existe(agenda, Juan));

        // 5. Eliminación de Clave (Nombre)
        System.out.println("\n--- Eliminando a Juan ---");
        agenda.Eliminar(Juan);

        // 6. Verificación Final
        System.out.println("¿Martin sigue en la agenda?: " + existe(agenda, Martin));
        System.out.println("¿Juan sigue en la agenda?: " + existe(agenda, Juan));
    }
//ejemplo de output
--- Cargando Agenda ---
Contacto: Martin registrado.
Contacto: Juan registrado.

--- Actualizando teléfono de Martin ---

--- Eliminando a Juan ---

¿Martin sigue en la agenda?: true
¿Juan sigue en la agenda?: false
}
